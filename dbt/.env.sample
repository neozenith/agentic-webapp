# dbt sidecar configuration. Copy to .env for local runs (the profile reads the
# GCP_/BIGQUERY_ vars; the sidecar reads DBT_TARGET/DBT_PROJECT_DIR/PORT).

# GCP project that owns the BigQuery dataset (the dbt `database`). Required.
GCP_PROJECT=dbt-dev-jaffleshop

# BigQuery dataset that holds the raw `extractions` table AND receives the
# staging views + mart tables. Defaults to agentic_webapp if unset.
BIGQUERY_DATASET=agentic_webapp

# BigQuery location/region for the dataset. Defaults to australia-southeast1.
BIGQUERY_LOCATION=australia-southeast1

# Which profile target to use: dev | test | prod. Defaults to dev.
DBT_TARGET=dev

# Directory containing dbt_project.yml + profiles.yml. Leave blank locally to
# use the bundled project; set to /app in the container.
DBT_PROJECT_DIR=

# Port the FastAPI sidecar listens on. Defaults to 8082.
PORT=8082
