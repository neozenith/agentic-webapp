# Copy to .env for local runs. Defaults give a fully LOCAL, GCP-free dev loop:
# in-memory storage + in-memory database. Switch backends to gcs/bigquery to use GCP.

ENVIRONMENT=local

# --- Backend selection (explicit; no silent fallback) ---
# storage: memory | gcs
STORAGE_BACKEND=memory
# database: memory | bigquery
DATABASE_BACKEND=memory

# --- GCP settings (required only when a gcp backend is selected) ---
# GCP_PROJECT=dbt-dev-jaffleshop
# ASSETS_BUCKET=dbt-dev-jaffleshop-agentic-webapp-assets
# BIGQUERY_DATASET=agentic_webapp
# ASSET_METADATA_TABLE=asset_metadata
# SIGNING_SERVICE_ACCOUNT=agentic-webapp-run@dbt-dev-jaffleshop.iam.gserviceaccount.com

# --- Misc ---
# Where assets are pulled to when combining (project-local per repo rules).
TEMP_DIR=tmp
# Default lifetime of generated signed URLs.
SIGNED_URL_TTL_SECONDS=900
LOG_LEVEL=DEBUG
PORT=8080
