{
	"$schema": "https://design-tokens.github.io/community-group/format/",
	"$description": "Zurich Australia DARK mode. Deep navy backgrounds, white text, cyan accent for primary CTAs. Names match this app's shadcn/ui CSS variable set 1:1 (no sidebar-* / chart-*).",
	"color": {
		"$type": "color",
		"background": { "$value": "{color.navy.900}" },
		"foreground": { "$value": "{color.white}" },
		"card": { "$value": "{color.navy.700}" },
		"card-foreground": { "$value": "{color.white}" },
		"popover": { "$value": "{color.navy.700}" },
		"popover-foreground": { "$value": "{color.white}" },
		"primary": { "$value": "{color.cyan-accent.400}" },
		"primary-foreground": { "$value": "{color.navy.900}" },
		"secondary": { "$value": "{color.navy.700}" },
		"secondary-foreground": { "$value": "{color.white}" },
		"muted": { "$value": "{color.navy.700}" },
		"muted-foreground": { "$value": "{color.zurich-blue.300}" },
		"accent": { "$value": "{color.zurich-blue.500}" },
		"accent-foreground": { "$value": "{color.white}" },
		"destructive": { "$value": "{color.rose.500}" },
		"destructive-foreground": { "$value": "{color.white}" },
		"border": { "$value": "{color.navy.700}" },
		"input": { "$value": "{color.navy.700}" },
		"ring": { "$value": "{color.cyan-accent.400}" }
	}
}
