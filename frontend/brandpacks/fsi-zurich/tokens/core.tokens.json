{
	"$schema": "https://design-tokens.github.io/community-group/format/",
	"$description": "Core tokens for Zurich Australia. Source: scraped from https://www.zurich.com.au/. Primary navy and Zurich blue captured from computed body color and most-frequent rendered colors.",
	"color": {
		"$type": "color",
		"zurich-blue": {
			"50": { "$value": "#EAF2F9" },
			"100": { "$value": "#D5E5F3" },
			"200": { "$value": "#ABCBE7" },
			"300": { "$value": "#91BFE3" },
			"400": { "$value": "#5495CF" },
			"500": { "$value": "#2167AE" },
			"600": { "$value": "#195389" },
			"700": { "$value": "#143F69" },
			"800": { "$value": "#0F2D4C" },
			"900": { "$value": "#0A1E33" }
		},
		"navy": {
			"50": { "$value": "#EDF1F9" },
			"100": { "$value": "#D7DCEA" },
			"300": { "$value": "#7B89B8" },
			"500": { "$value": "#23366F" },
			"700": { "$value": "#1A2858" },
			"900": { "$value": "#101933" }
		},
		"cyan-accent": {
			"400": { "$value": "#1FB1E6" }
		},
		"neutral": {
			"50": { "$value": "#F6F8FB" },
			"100": { "$value": "#ECEEEF" },
			"200": { "$value": "#DDE4E3" },
			"400": { "$value": "#A0AEC0" },
			"500": { "$value": "#64748B" },
			"800": { "$value": "#1E293B" },
			"900": { "$value": "#0F172A" }
		},
		"rose": { "500": { "$value": "#DC2626" } },
		"white": { "$value": "#FFFFFF" },
		"black": { "$value": "#0A0A0A" }
	},
	"radius": {
		"$type": "dimension",
		"base": { "$value": "0.75rem" }
	},
	"font": {
		"sans": {
			"$type": "fontFamily",
			"$value": [
				"ZurichSans-Light",
				"Arial",
				"ui-sans-serif",
				"system-ui",
				"sans-serif"
			]
		}
	}
}
