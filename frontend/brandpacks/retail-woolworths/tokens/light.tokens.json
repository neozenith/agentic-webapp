{
	"$schema": "https://design-tokens.github.io/community-group/format/",
	"$description": "Woolworths Group LIGHT mode. White surfaces, near-black ink, corporate blue primary. Names match this app's shadcn/ui CSS variable set 1:1 (no sidebar-* / chart-*).",
	"color": {
		"$type": "color",
		"background": { "$value": "{color.white}" },
		"foreground": { "$value": "{color.ink.deep}" },
		"card": { "$value": "{color.white}" },
		"card-foreground": { "$value": "{color.ink.deep}" },
		"popover": { "$value": "{color.white}" },
		"popover-foreground": { "$value": "{color.ink.deep}" },
		"primary": { "$value": "{color.ww-blue.500}" },
		"primary-foreground": { "$value": "{color.white}" },
		"secondary": { "$value": "{color.ww-blue.50}" },
		"secondary-foreground": { "$value": "{color.ww-blue.700}" },
		"muted": { "$value": "{color.neutral.100}" },
		"muted-foreground": { "$value": "{color.ink.medium}" },
		"accent": { "$value": "{color.ww-blue.50}" },
		"accent-foreground": { "$value": "{color.ww-blue.700}" },
		"destructive": { "$value": "{color.rose.500}" },
		"destructive-foreground": { "$value": "{color.white}" },
		"border": { "$value": "{color.neutral.200}" },
		"input": { "$value": "{color.neutral.200}" },
		"ring": { "$value": "{color.ww-blue.500}" }
	}
}
