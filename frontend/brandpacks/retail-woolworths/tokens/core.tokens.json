{
	"$schema": "https://design-tokens.github.io/community-group/format/",
	"$description": "Core tokens for Woolworths Group. Source: scraped from https://www.woolworthsgroup.com.au/. Primary blue #1971ED captured from logo and CTAs; near-black #202020 from body color; deep navy #0E0D26 used as headline accent. A green tone (#288144) is also retained from the rendered palette to nod to the supermarket banner.",
	"color": {
		"$type": "color",
		"ww-blue": {
			"50": { "$value": "#EBF3FE" },
			"100": { "$value": "#D6E7FD" },
			"200": { "$value": "#A8CDFA" },
			"300": { "$value": "#7AB3F7" },
			"400": { "$value": "#4D99F4" },
			"500": { "$value": "#1971ED" },
			"600": { "$value": "#0E5BC6" },
			"700": { "$value": "#0A4595" },
			"800": { "$value": "#072F66" },
			"900": { "$value": "#031736" }
		},
		"ink": {
			"navy": { "$value": "#0E0D26" },
			"deep": { "$value": "#202020" },
			"medium": { "$value": "#444464" },
			"light": { "$value": "#80808F" }
		},
		"green": {
			"500": { "$value": "#288144" },
			"600": { "$value": "#1F6B36" }
		},
		"neutral": {
			"50": { "$value": "#F7FCFF" },
			"100": { "$value": "#F2F2F2" },
			"200": { "$value": "#E5E7EA" },
			"300": { "$value": "#C4C4C4" },
			"500": { "$value": "#808080" },
			"700": { "$value": "#333333" },
			"900": { "$value": "#121212" }
		},
		"rose": { "500": { "$value": "#DC2626" } },
		"white": { "$value": "#FFFFFF" },
		"black": { "$value": "#000000" }
	},
	"radius": {
		"$type": "dimension",
		"base": { "$value": "0.5rem" }
	},
	"font": {
		"sans": {
			"$type": "fontFamily",
			"$value": [
				"Montserrat",
				"Tomato Grotesk",
				"ui-sans-serif",
				"system-ui",
				"Helvetica",
				"Arial",
				"sans-serif"
			]
		}
	}
}
