# Copy to .env for local runs.
# Keyless Vertex AI (uses your ADC locally; the agent SA in cloud).
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=dbt-dev-jaffleshop
# Vertex model-serving region (independent of GCS/BQ region). Flash-Lite is reliably in us-central1.
GOOGLE_CLOUD_LOCATION=us-central1
# Cheapest model by default; override to experiment.
AGENT_MODEL=gemini-2.5-flash-lite
# adk web port (the sidecar's localhost port; backend proxies to it).
PORT=8081
# Where the agent's asset tools reach the backend (the asset source of truth). localhost
# works for `make dev` and the single Cloud Run service; docker compose uses http://backend:8080.
BACKEND_BASE_URL=http://localhost:8080
