# Scratch space (see global tmp/ rule) — also holds tmp/archived/ (mv'd files).
tmp/
.DS_Store

# Local agent config (own repo).
.claude/

# Python bytecode (top-level scripts/ has no subproject .gitignore to catch it).
__pycache__/
*.pyc

# Generated OpenAPI contract dump (regenerate with `make -C backend openapi`; the live
# /openapi.json endpoint is the always-fresh source of truth).
backend/openapi.json

# Coverage + test artifacts (pytest-cov, vitest v8, emulator logs).
.coverage
coverage/
htmlcov/
.pytest_cache/
.mmdc_cache/
.vitest/
.playwright-cli/
